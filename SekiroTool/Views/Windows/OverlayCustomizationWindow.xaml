<Window x:Class="SekiroTool.Views.Windows.OverlayCustomizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Customize Browser Overlay"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="680"
        Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,10,0,6" />
        </Style>
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Margin" Value="0,6,0,4" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="130" />
        </Style>
        <Style x:Key="FieldRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
        <Style x:Key="ColorSwatchStyle" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Customize Browser Overlay"
                               Grid.Column="0"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="10,6" />

                    <Button Content="✕"
                            Grid.Column="1"
                            Width="30"
                            Height="30"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E81123" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15,10,15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Text Labels" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font family" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="LabelFontFamilyComboBox" Width="180" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font size" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="LabelFontSizeUpDown" Width="80" Minimum="6" Maximum="72"
                                           Increment="1" FormatString="F0" TextAlignment="Center" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}" />
                        <Border x:Name="LabelColorSwatch" Style="{StaticResource ColorSwatchStyle}" />
                        <TextBox x:Name="LabelColorTextBox" Width="140" />
                    </StackPanel>

                    <TextBlock Text="Values (HP / Posture / Act)" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font family" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="ValueFontFamilyComboBox" Width="180" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font size" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="ValueFontSizeUpDown" Width="80" Minimum="6" Maximum="72"
                                           Increment="1" FormatString="F0" TextAlignment="Center" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}" />
                        <Border x:Name="ValueColorSwatch" Style="{StaticResource ColorSwatchStyle}" />
                        <TextBox x:Name="ValueColorTextBox" Width="140" />
                    </StackPanel>

                    <TextBlock Text="Hit Counter" Style="{StaticResource SectionHeaderStyle}" />

                    <TextBlock Text="Current Hits" Style="{StaticResource SubHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font family" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="HitCountFontFamilyComboBox" Width="180" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font size" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="HitCountFontSizeUpDown" Width="80" Minimum="6" Maximum="72"
                                           Increment="1" FormatString="F0" TextAlignment="Center" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}" />
                        <Border x:Name="HitCountColorSwatch" Style="{StaticResource ColorSwatchStyle}" />
                        <TextBox x:Name="HitCountColorTextBox" Width="140" />
                    </StackPanel>

                    <TextBlock Text="Stagger Threshold" Style="{StaticResource SubHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font family" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="StaggerFontFamilyComboBox" Width="180" IsEditable="True" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Font size" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="StaggerFontSizeUpDown" Width="80" Minimum="6" Maximum="72"
                                           Increment="1" FormatString="F0" TextAlignment="Center" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}" />
                        <Border x:Name="StaggerColorSwatch" Style="{StaticResource ColorSwatchStyle}" />
                        <TextBox x:Name="StaggerColorTextBox" Width="140" />
                    </StackPanel>

                    <TextBlock Text="Poise Bar" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Fill color" Style="{StaticResource FieldLabelStyle}" />
                        <Border x:Name="BarColorSwatch" Style="{StaticResource ColorSwatchStyle}" />
                        <TextBox x:Name="BarColorTextBox" Width="140" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Text" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Hits to stagger label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="HitsLabelTextBox" Width="180" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="HP label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="HpLabelTextBox" Width="180" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Posture label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="PostureLabelTextBox" Width="180" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Poise timer label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="PoiseTimerLabelTextBox" Width="180" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Act label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="ActLabelTextBox" Width="180" />
                    </StackPanel>
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Kengeki label" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="KengekiLabelTextBox" Width="180" />
                    </StackPanel>

                    <TextBlock Text="Layout" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Row height" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="RowHeightUpDown" Width="80" Minimum="10" Maximum="150"
                                           Increment="1" FormatString="F0" TextAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Transparency" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Style="{StaticResource FieldRowStyle}">
                        <TextBlock Text="Background opacity" Style="{StaticResource FieldLabelStyle}" />
                        <xctk:DoubleUpDown x:Name="BackgroundOpacityUpDown" Width="80" Minimum="0" Maximum="1"
                                           Increment="0.05" FormatString="F2" TextAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Visibility" Style="{StaticResource SectionHeaderStyle}" />
                    <CheckBox x:Name="ShowLabelsCheckBox" Content="Show labels" />
                    <CheckBox x:Name="ShowHitsRowCheckBox" Content="Show hits to stagger" />
                    <CheckBox x:Name="ShowPoiseBarCheckBox" Content="Show poise bar" />
                    <CheckBox x:Name="ShowHpCheckBox" Content="Show HP" />
                    <CheckBox x:Name="ShowPostureCheckBox" Content="Show posture" />
                    <CheckBox x:Name="ShowPoiseTimerCheckBox" Content="Show poise timer" />
                    <CheckBox x:Name="ShowActKengekiCheckBox" Content="Show last act / kengeki" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="10,5,10,10">

                <Button x:Name="ResetButton"
                        Content="Reset to Defaults"
                        Width="120"
                        Height="26"
                        Margin="0,0,8,0"
                        Click="ResetButton_Click" />

                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="75"
                        Height="26"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click" />

                <Button x:Name="SaveButton"
                        Content="Save"
                        Width="75"
                        Height="26"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
