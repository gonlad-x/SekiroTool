<Window x:Class="SekiroTool.Views.Windows.TargetOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="230"
        Topmost="True">

    <Border Background="#1E1E1E"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="4"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>

        <StackPanel>
            <Border Background="#2A2A2A"
                    CornerRadius="3,3,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Target Overlay"
                               Foreground="#BBBBBB"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,5" />
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="22" Height="22"
                            Margin="0,0,4,0"
                            FontSize="10"
                            Cursor="Hand"
                            Click="Close_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#888">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#888" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C93D3D" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <StackPanel Margin="10,8,10,10">
                <Grid Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Nb of hits: " Foreground="#888" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding HitCount, StringFormat={}{0:F1}, Mode=OneWay}"
                                   Foreground="Gold" FontSize="16" FontWeight="SemiBold"
                                   MinWidth="32" TextAlignment="Right" VerticalAlignment="Center" />
                        <TextBlock Text=" / " Foreground="#888" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StaggerThreshold, StringFormat={}{0:F1}, Mode=OneWay}"
                                   Foreground="#888" FontSize="14"
                                   MinWidth="32" TextAlignment="Left" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Command="{Binding ResetHitCountCommand}"
                            Width="20" Height="20"
                            ToolTip="Reset hit count">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#666" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CCC" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="↺" FontSize="13" />
                    </Button>
                </Grid>

                <ProgressBar Height="20"
                             Value="{Binding TargetCurrentPoise, Mode=OneWay}"
                             Maximum="{Binding TargetMaxPoise, FallbackValue=100}">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border BorderBrush="#444" BorderThickness="1" Background="#222" CornerRadius="3">
                                <Grid x:Name="PART_Track">
                                    <Rectangle x:Name="PART_Indicator"
                                               Fill="#4CAF50"
                                               HorizontalAlignment="Left"
                                               RadiusX="2" RadiusY="2"
                                               Margin="1" />
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="13">
                                        <Run Text="{Binding TargetCurrentPoise, StringFormat={}{0:F1}, Mode=OneWay}" />
                                        <Run Text="/" />
                                        <Run Text="{Binding TargetMaxPoise, StringFormat={}{0:F1}, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>

                <TextBlock Text="{Binding TargetPoiseTimer, StringFormat={}Poise timer: {0:F1}s, Mode=OneWay}"
                           Foreground="#AAAAAA"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,3,0,8" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Act: " Foreground="#888" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastAct, Mode=OneWay}"
                               Foreground="Gold"
                               FontSize="14"
                               Width="24"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />
                    <TextBlock Text="Kengeki: " Foreground="#888" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastKengekiAct, Mode=OneWay}"
                               Foreground="Gold"
                               FontSize="14"
                               Width="24"
                               TextAlignment="Right"
                               VerticalAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>
