<UserControl x:Class="SekiroTool.Views.Tabs.StartupTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="StartupItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <CheckBox IsChecked="{Binding IsEnabled}"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center" />
                <TextBlock Text="{Binding DisplayName}"
                           Width="170"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Margin="5">
        <Border BorderThickness="1" BorderBrush="#333" CornerRadius="3" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="Activate on Game Load" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock Text="Checked options are activated once, when the game and/or SekiroTool are opened."
                           Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                        Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Active on game load:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3" />
                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                   Foreground="#AAAAAA" FontSize="11" />
                    </StackPanel>
                </Border>

                <TabControl Margin="0,5,0,0">
                    <TabItem Header="Player">
                        <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PlayerOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Enemies">
                        <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding EnemiesOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Target">
                        <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TargetOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Boss Skips">
                        <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BossSkipOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Border>

        <Border BorderThickness="1" BorderBrush="#333" CornerRadius="3">
            <StackPanel Margin="10">
                <TextBlock Text="Activate on New Game Cycle" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBlock Text="Checked options are (re)activated every time a New Game is started, even if the game and SekiroTool are already running."
                           Foreground="#888" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />

                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                        Padding="8,6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Active on New Game:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,3" />
                        <TextBlock Text="{Binding NewGameSummary}" TextWrapping="Wrap"
                                   Foreground="#AAAAAA" FontSize="11" />
                    </StackPanel>
                </Border>

                <TabControl Margin="0,5,0,0">
                    <TabItem Header="Player">
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NewGamePlayerOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Event">
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding EventOptions}"
                                          Padding="5"
                                          ItemTemplate="{StaticResource StartupItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
